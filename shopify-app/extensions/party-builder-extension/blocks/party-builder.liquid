{% comment %}
  PartyTees Party Builder - Theme App Extension Block
  This block embeds the custom t-shirt builder into your Shopify theme
{% endcomment %}

{% schema %}
{
  "name": "Party Builder",
  "target": "section",
  "stylesheet": "party-builder.css",
  "javascript": "party-builder.js",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "Backend API URL",
      "default": "https://party-tees.preview.emergentagent.com/api",
      "info": "The URL of your PartyTees backend API"
    },
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product Handle",
      "default": "custom-party-tshirt",
      "info": "The handle of the Shopify product for custom t-shirts"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Create Your Party T-Shirt"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Section Description",
      "default": "<p>Upload a photo, choose a hilarious template, and create custom t-shirts for your party!</p>"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#FF2E63"
    },
    {
      "type": "color",
      "id": "secondary_color", 
      "label": "Secondary Color",
      "default": "#08D9D6"
    },
    {
      "type": "range",
      "id": "base_price",
      "label": "Base Price (pence)",
      "min": 1000,
      "max": 5000,
      "step": 50,
      "default": 1999,
      "info": "Price in pence (1999 = £19.99)"
    },
    {
      "type": "range",
      "id": "back_print_price",
      "label": "Back Print Price (pence)",
      "min": 0,
      "max": 1000,
      "step": 50,
      "default": 250,
      "info": "Additional price for back print in pence (250 = £2.50)"
    }
  ]
}
{% endschema %}

<div 
  id="party-builder-app" 
  class="party-builder-container"
  data-api-url="{{ block.settings.api_url }}"
  data-product-handle="{{ block.settings.product_handle }}"
  data-primary-color="{{ block.settings.primary_color }}"
  data-secondary-color="{{ block.settings.secondary_color }}"
  data-base-price="{{ block.settings.base_price }}"
  data-back-print-price="{{ block.settings.back_print_price }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-currency="{{ cart.currency.iso_code }}"
>
  {% if block.settings.heading != blank %}
    <h2 class="party-builder-heading">{{ block.settings.heading }}</h2>
  {% endif %}
  
  {% if block.settings.description != blank %}
    <div class="party-builder-description">{{ block.settings.description }}</div>
  {% endif %}
  
  <!-- Loading state while React app initializes -->
  <div id="party-builder-loading" class="party-builder-loading">
    <div class="party-builder-spinner"></div>
    <p>Loading Party Builder...</p>
  </div>
  
  <!-- React app will mount here -->
  <div id="party-builder-root"></div>
</div>

<style>
  .party-builder-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  
  .party-builder-heading {
    font-family: 'Anton', sans-serif;
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 1rem;
    color: #252A34;
    letter-spacing: 0.05em;
  }
  
  .party-builder-description {
    text-align: center;
    color: #666;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .party-builder-loading {
    text-align: center;
    padding: 60px 20px;
  }
  
  .party-builder-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #eee;
    border-top-color: {{ block.settings.primary_color }};
    border-radius: 50%;
    animation: party-spin 1s linear infinite;
    margin: 0 auto 1rem;
  }
  
  @keyframes party-spin {
    to { transform: rotate(360deg); }
  }
  
  .party-builder-loading.hidden {
    display: none;
  }
</style>
